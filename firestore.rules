rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - bio: string
    //   - role: string (user, admin)
    //   - createdAt: timestamp
    //
    // Collection: messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - receiverId: string
    //   - text: string (required)
    //   - timestamp: timestamp (required)
    //   - roomId: string
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - authorId: string (required)
    //   - authorName: string
    //   - content: string (required)
    //   - imageUrl: string
    //   - likes: number
    //   - createdAt: timestamp (required)
    //
    // Collection: searchHistory
    // Document ID: {queryId}
    // Fields:
    //   - userId: string (required)
    //   - query: string (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: typing
    // Document ID: {typingId}
    // Fields:
    //   - userId: string (required)
    //   - userName: string
    //   - roomId: string (required)
    //   - isTyping: boolean (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jobsatespace@gmail.com" && request.auth.token.email_verified == true));
    }

    function isPremium() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('age' in data) || data.age is number) &&
             (!('country' in data) || data.country is string) &&
             (!('city' in data) || data.city is string) &&
             (!('gender' in data) || data.gender in ['male', 'female', 'other']) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() < 5000 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin()) &&
                    (request.resource.data.isPremium == resource.data.isPremium || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && (isPremium() || isAdmin());
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.members || 
        request.auth.uid in request.resource.data.members ||
        isAdmin()
      );
    }

    match /searchHistory/{queryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /typing/{typingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /paymentRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
